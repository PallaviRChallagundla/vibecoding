// ── TIMER ─────────────────────────────────────────────────────────────────
const showTimer = () => { S.tab='timer'; save(); if(TI)clearInterval(TI); renderTimer(); };
const renderTimer = () => {
  const l=S.tLeft, m=Math.floor(l/60), s=l%60;
  const disp=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  const pct=Math.round((1-l/S.tBase)*100);
  const r = S.activeRoom ? ROOMS.find(x=>x.id===S.activeRoom) : ROOMS[0];
  const ft = r.tasks.filter(t=>S.unlocked||t.free).slice(0,3);
  render(`${pbar('Focus mode')}${nav()}
<div class="gap"></div>
<div class="timer-box">
  <div class="t-lbl">Focused time</div>
  <div class="t-dig">${disp}</div>
  <div class="t-track"><div class="t-fill" style="width:${pct}%"></div></div>
  <div class="t-picks">
    <button class="tp${S.tMode===15?' on':''}" onclick="setT(15)">15 min</button>
    <button class="tp${S.tMode===30?' on':''}" onclick="setT(30)">30 min</button>
    <button class="tp${S.tMode===60?' on':''}" onclick="setT(60)">60 min</button>
  </div>
  <div class="t-btns">
    <button class="tb tb-r" onclick="resetT()">Reset</button>
    <button class="tb tb-s" onclick="togT()">${S.tOn?'Pause':'Start'}</button>
  </div>
</div>
<div style="font-family:var(--fs);font-size:14px;font-style:italic;color:var(--mid);text-align:center;padding:.75rem 2rem 1rem;line-height:1.75">"Put on a podcast. Light a candle. Set the timer. Stop when it rings — no guilt."</div>
<div style="margin:0 1.375rem;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:1.125rem">
  <div class="task-hd-title" style="margin-bottom:.75rem">Focus tasks</div>
  ${ft.map(t=>{const dn=!!S.tasks[t.id];return`<div class="tr${dn?' done':''}" onclick="toggleTask('${t.id}')"><div class="chk${dn?' on':''}">${cv()}</div><div class="td"><span class="tn">${t.t}</span><div class="tmeta">${t.m}</div></div></div>`;}).join('')}
</div><div class="gap2"></div>`);
};
const setT = m => { if(TI)clearInterval(TI); S.tOn=false;S.tMode=m;S.tLeft=m*60;S.tBase=m*60;save();renderTimer(); };
const resetT = () => { if(TI)clearInterval(TI); S.tOn=false;S.tLeft=S.tBase;save();renderTimer(); };
const togT = () => {
  if(S.tOn){clearInterval(TI);S.tOn=false;save();renderTimer();return;}
  S.tOn=true;save();renderTimer();
  TI=setInterval(()=>{
    if(S.tLeft<=0){clearInterval(TI);S.tOn=false;S.tLeft=0;save();
      render(`<div class="done-screen"><div style="font-size:48px;margin-bottom:1.125rem">🌿</div><div class="t-section" style="margin-bottom:.5rem">Session done.</div><p class="t-body" style="max-width:240px;margin:0 auto 2rem">You showed up for your home today. That's the whole point.</p><button class="btn btn-s" style="max-width:220px;margin:0 auto" onclick="setTab('rooms')">See my progress →</button></div>`);return;
    }
    S.tLeft--;save();renderTimer();
  },1000);
};

// ── INIT ──────────────────────────────────────────────────────────────────
const tabMap = {diff:showDiff,shop:showShop,scent:showScent,flowers:showFlowers,guide:showGuide};
if(S.scr==='ob')renderOb();
else if(S.tab==='timer'){S.tOn=false;save();showRooms();}
else if(tabMap[S.tab]){tabMap[S.tab]();}
else if(S.ob.q0!==undefined)showRooms();
else showWelcome();
</script>
