const toggleTask = id => {
  const task = ROOMS.flatMap(r=>r.tasks).find(t=>t.id===id);
  if (!task) return;
  if (!S.unlocked && !task.free) { showGuide(); return; }
  S.tasks[id] = !S.tasks[id]; save();
  if (S.activeRoom) showRoom(S.activeRoom);
