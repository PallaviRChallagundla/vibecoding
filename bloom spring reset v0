</div>${nav()}
<div class="shop-cats">${catBtns}</div>
<div class="px pb">${list}</div>
<div style="padding:.5rem 1.375rem 1.5rem;font-size:11px;color:var(--muted);line-height:1.7">Prices are approximate and may vary. Tap any item to shop at the retailer directly. Bloom may earn a small affiliate commission — at no extra cost to you.</div>`);
