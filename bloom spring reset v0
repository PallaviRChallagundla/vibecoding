  const v = el('eIn')?el('eIn').value:'';
  if (!v||!v.includes('@')) { if(el('eIn'))el('eIn').style.borderColor='var(--rose)'; return; }
  // ── PRODUCTION: POST to Mailchimp / ConvertKit API here ──
  // fetch('/api/subscribe', {method:'POST',body:JSON.stringify({email:v})})
  S.unlocked=true; S.email=v; save();
  render(`<div class="done-screen">
    <div style="font-size:48px;margin-bottom:1.125rem">🌸</div>
    <div class="t-section" style="margin-bottom:.5rem">All unlocked.</div>
    <p class="t-body" style="max-width:260px;margin:0 auto 2rem">All 10 rooms, every task, every candle and flower guide — plus your printable PDF is on its way to ${v}.</p>
