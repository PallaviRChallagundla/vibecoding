<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>Bloom — Spring Home Reset 2025</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --f:'DM Sans',sans-serif;
  --fs:'Playfair Display',serif;
  --cream:#faf8f3;
  --white:#ffffff;
  --petal:#f2e8e1;
  --blush:#e8d5cc;
  --sage:#3a6648;
  --sage2:#4e8860;
  --sage3:#8dbfa0;
  --sagep:#ecf4ee;
  --gold:#b8892e;
  --goldp:#fbf3e3;
  --goldb:#e5d09a;
  --rose:#b5665e;
  --rosep:#fbedeb;
  --ink:#1a1917;
  --mid:#585650;
  --muted:#8a877e;
  --border:#e6ded5;
  --r:12px;--rl:18px;--rxl:26px;
}
html,body{background:var(--cream);font-family:var(--f);color:var(--ink);font-size:15px;min-height:100vh}
#app{max-width:430px;margin:0 auto;background:var(--white);min-height:100vh;position:relative}
#screen{animation:up .3s ease both}
@keyframes up{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* TYPE */
.serif{font-family:var(--fs)}
.t-eyebrow{font-size:10px;letter-spacing:3px;text-transform:uppercase;font-weight:400;color:var(--muted)}
.t-hero{font-family:var(--fs);font-size:40px;font-weight:400;line-height:1.1;color:var(--ink)}
.t-hero em{font-style:italic;color:var(--sage)}
.t-section{font-family:var(--fs);font-size:22px;font-weight:400;line-height:1.25}
.t-card{font-family:var(--fs);font-size:17px;font-weight:400;line-height:1.3}
.t-body{font-size:13px;color:var(--mid);line-height:1.75;font-weight:300}
.t-micro{font-size:11px;color:var(--muted);font-weight:300}

/* LAYOUT */
.px{padding:0 1.375rem}.pt{padding-top:1.5rem}.pb{padding-bottom:2rem}
.gap{height:.875rem}.gap2{height:1.75rem}
.rule{height:1px;background:var(--border);margin:.75rem 1.375rem}

/* BUTTONS */
.btn{display:block;width:100%;padding:14px;border-radius:var(--r);font-family:var(--f);font-size:14px;font-weight:500;cursor:pointer;text-align:center;border:none;transition:all .18s}
.btn-s{background:var(--sage);color:#fff}.btn-s:hover{background:var(--sage2)}.btn-s:active{transform:scale(.98)}
.btn-g{background:var(--gold);color:#fff}.btn-g:active{transform:scale(.98)}
.btn-o{background:transparent;border:1.5px solid var(--sage);color:var(--sage);margin-top:8px}.btn-o:hover{background:var(--sagep)}
.btn-ghost{background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer;font-family:var(--f);padding:5px 0}

/* TOP NAV */
.topnav{background:var(--white);border-bottom:1px solid var(--border);display:flex;overflow-x:auto;scrollbar-width:none;position:sticky;top:0;z-index:30}
.topnav::-webkit-scrollbar{display:none}
.tn{flex:1;min-width:50px;padding:12px 4px 11px;font-size:11px;font-weight:500;letter-spacing:.3px;cursor:pointer;border-bottom:2.5px solid transparent;color:var(--muted);background:none;border-top:none;border-left:none;border-right:none;font-family:var(--f);text-align:center;white-space:nowrap;transition:all .18s}
.tn.on{color:var(--sage);border-bottom-color:var(--sage)}

/* PROGRESS STRIP */
.pbar{background:var(--sage);padding:1.125rem 1.375rem 1.375rem}
.pbar-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.5rem}
.pbar-title{font-family:var(--fs);font-size:18px;color:#fff;font-weight:400;font-style:italic}
.pbar-n{font-size:26px;font-weight:500;color:#fff;line-height:1}
.pbar-s{font-size:11px;color:rgba(255,255,255,.38);margin-top:1px}
.pbar-track{background:rgba(255,255,255,.18);border-radius:99px;height:4px;overflow:hidden}
.pbar-fill{height:100%;background:var(--gold);border-radius:99px;transition:width .7s cubic-bezier(.4,0,.2,1)}

/* WELCOME HERO */
.w-cover{background:var(--sage);min-height:300px;display:flex;flex-direction:column;justify-content:flex-end;padding:2.25rem 1.5rem 2rem;position:relative;overflow:hidden}
.w-cover::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(40,80,55,.2) 0%,rgba(40,80,55,.85) 100%)}
.w-cover-img{position:absolute;inset:0;font-size:200px;display:flex;align-items:center;justify-content:center;opacity:.08;filter:blur(2px);pointer-events:none;user-select:none}
.w-cover-content{position:relative}
.w-tag{font-size:10px;letter-spacing:3px;color:rgba(255,255,255,.5);text-transform:uppercase;margin-bottom:1rem}
.w-title{font-family:var(--fs);font-size:42px;font-weight:400;color:#fff;line-height:1.05;margin-bottom:.6rem}
.w-title em{font-style:italic;color:var(--sage3)}
.w-sub{font-size:13px;color:rgba(255,255,255,.55);line-height:1.8;max-width:260px;margin-bottom:1.25rem;font-weight:300}
.w-proof{display:flex;align-items:center;gap:7px}
.w-stars{color:var(--gold);font-size:11px;letter-spacing:2px}
.w-pt{font-size:11px;color:rgba(255,255,255,.38)}

/* ROOM CARDS — pinterest editorial grid */
.rooms-list{padding:1rem 1.375rem;display:flex;flex-direction:column;gap:10px}
.rc{background:var(--white);border-radius:var(--rl);overflow:hidden;border:1px solid var(--border);cursor:pointer;transition:all .2s}
.rc:active{transform:scale(.99)}
.rc-header{height:110px;display:flex;align-items:flex-end;justify-content:space-between;padding:10px 14px;position:relative;overflow:hidden}
.rc-bg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:80px;opacity:.12;filter:blur(1px)}
.rc-tag{position:relative;font-size:10px;font-weight:500;letter-spacing:.4px;padding:4px 10px;border-radius:99px;backdrop-filter:blur(6px)}
.rc-pct{position:relative;font-size:12px;font-weight:500;opacity:.85}
.rc-body{padding:12px 16px 14px}
.rc-room{font-size:10px;font-weight:500;color:var(--muted);letter-spacing:.7px;text-transform:uppercase;margin-bottom:2px}
.rc-title{font-family:var(--fs);font-size:18px;font-weight:400;color:var(--ink);margin-bottom:5px}
.rc-sub{font-size:12px;color:var(--mid);line-height:1.65;margin-bottom:10px;font-weight:300}
.rc-chips{display:flex;gap:5px;margin-bottom:10px;flex-wrap:wrap}
.chip{font-size:10px;padding:3px 9px;border-radius:99px;border:1px solid var(--border);color:var(--mid);display:flex;align-items:center;gap:3px;white-space:nowrap}
.rc-foot{display:flex;align-items:center;gap:10px}
.rc-prog{flex:1;height:3px;background:var(--border);border-radius:99px;overflow:hidden}
.rc-prog-fill{height:100%;border-radius:99px;transition:width .5s}
.rc-cnt{font-size:11px;color:var(--muted);white-space:nowrap}
.rc-btn{font-size:12px;font-weight:500;color:var(--sage);padding:5px 11px;border:1px solid var(--sage);border-radius:99px;background:transparent;cursor:pointer;font-family:var(--f);white-space:nowrap;transition:all .18s}
.rc-btn:hover{background:var(--sagep)}
.rc-btn.done{background:var(--sage);color:#fff;border-color:var(--sage)}

/* ROOM DETAIL */
.rd-cover{height:150px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.rd-bg{position:absolute;font-size:100px;opacity:.12}
.rd-inner{position:relative;text-align:center;padding:0 1.5rem}
.rd-eyebrow{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;opacity:.6;margin-bottom:.35rem}
.rd-h{font-family:var(--fs);font-size:26px;font-weight:400;line-height:1.2}
.rd-h em{font-style:italic}

.rd-body{padding:1.125rem 1.375rem 2.5rem}
.rd-quote{font-family:var(--fs);font-size:15px;font-style:italic;line-height:1.8;color:var(--mid);margin-bottom:1.125rem;padding-bottom:1.125rem;border-bottom:1px solid var(--border)}
.vibes{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:1.125rem}
.vibe{background:var(--cream);border:1px solid var(--border);border-radius:var(--r);padding:9px 7px;text-align:center}
.vibe-i{font-size:18px;display:block;margin-bottom:3px}
.vibe-l{font-size:9px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:1px}
.vibe-v{font-family:var(--fs);font-size:11px;font-style:italic;color:var(--ink);display:block;line-height:1.4}

.detail-panel{background:var(--cream);border:1px solid var(--border);border-radius:var(--r);padding:.875rem 1rem;margin-bottom:1.125rem}
.dp-row{margin-bottom:.625rem}
.dp-row:last-child{margin-bottom:0}
.dp-label{font-size:10px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.dp-val{font-family:var(--fs);font-size:13px;font-style:italic;color:var(--ink);line-height:1.65}

.task-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
.task-hd-title{font-family:var(--fs);font-size:17px;font-weight:400}
.task-pill{font-size:11px;padding:3px 9px;border-radius:99px;background:var(--sagep);color:var(--sage);font-weight:500}

/* TASKS */
.tr{display:flex;align-items:flex-start;gap:10px;padding:11px 0;border-bottom:1px solid var(--border);cursor:pointer}
.tr:last-child{border-bottom:none}
.tr.lk{cursor:default;opacity:.3}
.tr:not(.lk):active{opacity:.65}
.chk{width:21px;height:21px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s;margin-top:1px;background:var(--white)}
.chk.on{background:var(--sage);border-color:var(--sage)}
.chk svg{display:none;width:10px;height:8px;stroke:#fff;stroke-width:2.5;fill:none}
.chk.on svg{display:block}
.lkico{width:12px;height:12px;flex-shrink:0;opacity:.35;margin-top:3px}
.td{flex:1}
.tn{font-size:13px;line-height:1.5;color:var(--ink)}
.tr.done .tn{text-decoration:line-through;color:var(--muted)}
.tmeta{font-size:11px;color:var(--muted);margin-top:2px}
.tbadge{font-size:10px;padding:1px 6px;border-radius:99px;font-weight:500;margin-left:4px;vertical-align:middle}
.tbd{background:#e6efea;color:#1a4228}.tbq{background:#fdf2df;color:#7a4a06}
.tbr{background:#e6eef9;color:#1a3a6b}.tbc{background:#fae6ea;color:#6b1a22}

/* DIFFICULTY VIEW */
.diff-chips{display:flex;gap:6px;padding:.875rem 1.375rem .5rem;overflow-x:auto;scrollbar-width:none}
.diff-chips::-webkit-scrollbar{display:none}
.dc{padding:7px 13px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid var(--border);background:var(--white);color:var(--mid);font-family:var(--f);transition:all .18s;white-space:nowrap}
.dc.on{color:#fff;border-color:transparent}
.dc[data-k="all"].on{background:var(--sage)}
.dc[data-k="tbq"].on{background:#c4973a}
.dc[data-k="tbc"].on{background:#a85060}
.dc[data-k="tbr"].on{background:#3070b0}
.dc[data-k="tbd"].on{background:var(--sage)}

.diff-banner{margin:.25rem 1.375rem .875rem;padding:.875rem 1rem;border-radius:var(--rl);border:1px solid}
.diff-banner.all{background:var(--cream);border-color:var(--border);color:var(--mid)}
.diff-banner.tbq{background:#fdf9ea;border-color:#e8d070;color:#7a4a06}
.diff-banner.tbc{background:#fdf0f3;border-color:#e0a8b5;color:#6b1a22}
.diff-banner.tbr{background:#eaf0fb;border-color:#a0c0e0;color:#1a3a6b}
.diff-banner.tbd{background:var(--sagep);border-color:var(--sage3);color:#1a4228}
.db-title{font-family:var(--fs);font-size:16px;font-weight:400;margin-bottom:3px}
.db-desc{font-size:12px;line-height:1.7;font-weight:300}

/* VISUAL CARDS — by difficulty */
.vgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 1.375rem .875rem}
.vc{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:12px;cursor:pointer;position:relative;overflow:hidden;transition:all .2s}
.vc:active{transform:scale(.965)}
.vc.done{opacity:.42}
.vc.lk{opacity:.28;cursor:default}
.vc-accent{position:absolute;top:0;left:0;right:0;height:3px;border-radius:0}
.vc-chk{position:absolute;top:9px;right:9px;width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;transition:all .2s}
.vc-chk.on{background:var(--sage);border-color:var(--sage)}
.vc-chk svg{display:none;width:9px;height:7px;stroke:#fff;stroke-width:2.5;fill:none}
.vc-chk.on svg{display:block}
.vc-lk{position:absolute;top:8px;right:8px;font-size:13px}
.vc-icon{font-size:22px;display:block;margin-bottom:6px;margin-top:2px;line-height:1}
.vc-name{font-size:12px;font-weight:500;color:var(--ink);line-height:1.45;margin-bottom:2px}
.vc.done .vc-name{text-decoration:line-through;color:var(--muted)}
.vc-room{font-size:10px;color:var(--muted)}
.vc-time{font-size:10px;color:var(--muted);margin-top:3px}

/* SHOP */
.shop-header{background:var(--sage);padding:1.625rem 1.375rem 2rem}
.shop-h{font-family:var(--fs);font-size:24px;color:#fff;font-weight:400;margin-bottom:.35rem}
.shop-s{font-size:12px;color:rgba(255,255,255,.48);line-height:1.7;font-weight:300}
.shop-subtotal{background:rgba(255,255,255,.1);border-radius:var(--r);padding:.625rem .875rem;margin-top:.875rem;display:flex;justify-content:space-between;align-items:center}

.shop-cats{display:flex;gap:6px;padding:.875rem 1.375rem .5rem;overflow-x:auto;scrollbar-width:none}
.shop-cats::-webkit-scrollbar{display:none}
.sc-btn{padding:7px 13px;border-radius:99px;font-size:11px;font-weight:500;cursor:pointer;border:1.5px solid var(--border);background:var(--white);color:var(--mid);transition:all .18s;white-space:nowrap;font-family:var(--f)}
.sc-btn.on{background:var(--sage);border-color:var(--sage);color:#fff}

.si{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);align-items:flex-start;text-decoration:none;color:inherit}
.si:last-child{border-bottom:none}
.si:active{opacity:.75}
.si-icon{width:42px;height:42px;border-radius:var(--r);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px}
.si-g{background:#ecf4ee}.si-b{background:#e8f0f8}.si-a{background:#fbf6e0}.si-p{background:#fbeaec}.si-v{background:#f0eefb}
.si-name{font-size:13px;font-weight:500;color:var(--ink);line-height:1.3}
.si-brand{font-size:10px;color:var(--muted);margin:1px 0 3px}
.si-why{font-size:11px;color:var(--mid);line-height:1.55}
.si-added{font-size:10px;color:var(--sage);font-weight:500;margin-top:3px}
.si-r{text-align:right;flex-shrink:0}
.si-price{font-size:13px;font-weight:500;color:var(--ink)}
.si-store{font-size:10px;color:var(--muted);margin-top:1px}
.si-add{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .18s;margin-top:5px;margin-left:auto;line-height:1}
.si-add.on{background:var(--sage);border-color:var(--sage);color:#fff;font-size:11px}

/* SCENTS */
.scent-card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:13px 15px;display:flex;gap:12px;align-items:flex-start;margin-bottom:8px;text-decoration:none;color:inherit;cursor:pointer;transition:opacity .18s}
.scent-card:active{opacity:.75}
.sco{width:46px;height:46px;border-radius:var(--r);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:23px}
.sc-name{font-family:var(--fs);font-size:16px;font-weight:400}
.sc-brand{font-size:10px;color:var(--muted);margin:1px 0 4px}
.sc-desc{font-size:12px;color:var(--mid);line-height:1.6}
.sc-rooms{font-size:10px;font-weight:500;padding:2px 8px;border-radius:99px;margin-top:5px;display:inline-block}
.sc-shop{font-size:11px;color:var(--sage);font-weight:500;margin-top:4px}

/* FLOWERS */
.flower-card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:14px 15px;margin-bottom:8px}
.fc-top{display:flex;gap:12px;align-items:flex-start;margin-bottom:8px}
.fc-icon{width:46px;height:46px;border-radius:var(--r);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:23px}
.fc-name{font-family:var(--fs);font-size:16px;font-weight:400}
.fc-season{font-size:10px;color:var(--muted);margin:1px 0 4px}
.fc-desc{font-size:12px;color:var(--mid);line-height:1.6;margin-bottom:3px}
.fc-where{font-size:11px;color:var(--sage);font-weight:500}
.fc-tip{background:var(--cream);border-radius:8px;padding:8px 10px;font-family:var(--fs);font-size:13px;font-style:italic;color:var(--mid);line-height:1.6;margin-top:8px;border:1px solid var(--border)}

/* GUIDE / EMAIL GATE */
.guide-cover{background:var(--sage);padding:2rem 1.5rem 2.25rem;text-align:center;position:relative;overflow:hidden}
.guide-cover::before{content:'✦';font-size:120px;color:rgba(255,255,255,.04);position:absolute;top:-20px;left:-10px;font-family:serif}
.gcover-tag{font-size:10px;letter-spacing:3px;color:rgba(255,255,255,.4);text-transform:uppercase;margin-bottom:1rem;position:relative}
.gcover-title{font-family:var(--fs);font-size:32px;font-weight:400;color:#fff;line-height:1.1;margin-bottom:.6rem;position:relative}
.gcover-title em{font-style:italic;color:var(--sage3)}
.gcover-sub{font-size:13px;color:rgba(255,255,255,.48);line-height:1.8;font-weight:300;max-width:270px;margin:0 auto;position:relative}

.pdf-preview{margin:1.125rem 1.375rem .875rem;background:var(--cream);border-radius:var(--rl);border:1px solid var(--border);overflow:hidden}
.pdf-preview-header{background:var(--sage);padding:.75rem 1.125rem}
.pdf-title{font-family:var(--fs);font-size:17px;font-style:italic;color:#fff}
.pdf-sub{font-size:11px;color:rgba(255,255,255,.45);margin-top:1px}
.pdf-pages{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;padding:.875rem}
.pdf-page{border-radius:8px;aspect-ratio:.72;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:20px;border:1px solid var(--border);position:relative;overflow:hidden}
.pdf-page-lbl{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.28);font-size:9px;color:#fff;text-align:center;padding:3px;font-weight:500;letter-spacing:.3px;text-transform:uppercase}

.includes{padding:.875rem 1.375rem}
.inc{display:flex;gap:9px;align-items:flex-start;padding:9px 10px;background:var(--cream);border-radius:var(--r);border:1px solid var(--border);margin-bottom:6px}
.inc-icon{font-size:16px;flex-shrink:0;margin-top:1px}
.inc-t{font-size:13px;font-weight:500;color:var(--ink)}
.inc-s{font-size:11px;color:var(--mid);margin-top:1px;line-height:1.5;font-weight:300}

.email-gate{margin:0 1.375rem .875rem;background:var(--petal);border:1px solid var(--blush);border-radius:var(--rl);padding:1.125rem}
.eg-title{font-family:var(--fs);font-size:18px;font-weight:400;margin-bottom:.3rem}
.eg-sub{font-size:12px;color:var(--mid);line-height:1.7;margin-bottom:.875rem;font-weight:300}
.eg-row{display:flex;gap:8px}
.eg-in{flex:1;padding:11px 12px;border:1.5px solid var(--blush);border-radius:var(--r);font-family:var(--f);font-size:13px;background:var(--white);color:var(--ink);outline:none;transition:border-color .18s}
.eg-in:focus{border-color:var(--sage)}
.eg-btn{padding:11px 14px;background:var(--sage);color:#fff;border:none;border-radius:var(--r);font-family:var(--f);font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap;transition:background .18s}
.eg-btn:hover{background:var(--sage2)}
.eg-note{font-size:11px;color:var(--muted);margin-top:.5rem;text-align:center}

.review-row{display:flex;gap:9px;padding:0 1.375rem .875rem;align-items:flex-start}
.rev-stars{color:var(--gold);font-size:14px;flex-shrink:0;margin-top:1px}
.rev-text{font-family:var(--fs);font-size:13px;font-style:italic;color:var(--mid);line-height:1.7}

/* AFFIRM */
.affirm{background:var(--petal);border:1px solid var(--blush);border-radius:var(--rl);padding:.875rem 1.125rem;margin:.875rem 1.375rem}
.affirm-text{font-family:var(--fs);font-size:14px;font-style:italic;color:#5a2a1a;line-height:1.75}

/* LOCK NUDGE */
.lock-nudge{background:var(--goldp);border:1.5px solid var(--goldb);padding:.875rem 1.375rem;display:flex;align-items:center;justify-content:space-between;margin:.625rem 1.375rem;border-radius:var(--r);cursor:pointer}
.ln-t{font-weight:500;font-size:13px;color:#5a3a08}
.ln-s{font-size:11px;color:#8a6018;margin-top:2px}
.ln-cta{font-size:13px;font-weight:500;color:var(--gold);white-space:nowrap}

/* ONBOARDING */
.ob-cover{background:var(--sage);padding:2rem 1.5rem 2.25rem}
.ob-bar{display:flex;gap:5px;margin-bottom:2rem}
.ob-seg{flex:1;height:3px;border-radius:99px;background:rgba(255,255,255,.18);transition:background .3s}
.ob-seg.on{background:rgba(255,255,255,.7)}
.ob-q{font-family:var(--fs);font-size:24px;font-weight:400;color:#fff;line-height:1.25;margin-bottom:.35rem}
.ob-hint{font-size:13px;color:rgba(255,255,255,.42);font-weight:300;line-height:1.65}
.ob-opts{padding:1.25rem 1.375rem 2.5rem;display:flex;flex-direction:column;gap:7px}
.ob-opt{display:block;width:100%;padding:12px 15px;text-align:left;background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);font-size:13px;cursor:pointer;font-family:var(--f);color:var(--ink);line-height:1.45;font-weight:300;transition:all .18s}
.ob-opt:hover{border-color:var(--sage2);background:var(--sagep)}
.ob-opt.on{border-color:var(--sage);background:var(--sagep);color:var(--sage);font-weight:500}

/* TIMER */
.timer-box{background:var(--sage);border-radius:var(--rl);margin:0 1.375rem 10px;padding:1.625rem 1.125rem 1.375rem;text-align:center}
.t-lbl{font-size:10px;letter-spacing:2px;color:rgba(255,255,255,.38);text-transform:uppercase;margin-bottom:.45rem}
.t-dig{font-family:var(--fs);font-size:68px;font-weight:400;color:#fff;letter-spacing:4px;line-height:1}
.t-track{background:rgba(255,255,255,.12);border-radius:99px;height:4px;margin:.875rem 0;overflow:hidden}
.t-fill{height:100%;background:var(--gold);border-radius:99px;transition:width 1s linear}
.t-picks{display:flex;gap:7px;justify-content:center;margin-bottom:.75rem}
.tp{padding:6px 14px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid rgba(255,255,255,.2);background:transparent;color:rgba(255,255,255,.48);font-family:var(--f);transition:all .18s}
.tp.on{background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.48);color:#fff}
.t-btns{display:flex;gap:8px;justify-content:center}
.tb{padding:9px 20px;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:var(--f);border:none;transition:all .18s}
.tb-s{background:var(--gold);color:#fff}.tb-r{background:rgba(255,255,255,.1);color:rgba(255,255,255,.68)}

/* DONE / SPINNER */
.done-screen{text-align:center;padding:4rem 2rem}
.spinner-wrap{text-align:center;padding:5rem 2rem}
.spinner{width:34px;height:34px;border:2.5px solid var(--sagep);border-top-color:var(--sage);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 1.25rem}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
