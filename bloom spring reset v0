  <div class="pdf-pages">
    <div class="pdf-page" style="background:#ecf4ee"><span>🌿</span><div class="pdf-page-lbl">Kitchen</div></div>
    <div class="pdf-page" style="background:var(--petal)"><span>🌸</span><div class="pdf-page-lbl">Bedroom</div></div>
    <div class="pdf-page" style="background:#fbf3e3"><span>🕯️</span><div class="pdf-page-lbl">Scents</div></div>
  </div>
</div>
<div class="includes px">
  ${[['🗺️','10 room mood boards','Each room with candle, flower suggestion and one seasonal swap'],['✅','Full task checklists','60+ tasks organised by room and difficulty — print and work through offline'],['🕯️','2025 scent guide','Exactly which candle for which room, with real prices and where to buy in NJ'],['💐','Spring flower guide','What\'s in season, where to find it, how to style it'],['✨','Winter → spring transition','The swaps for textiles, scent and decor that actually signal the season shift']].map(([i,t,d])=>`<div class="inc"><span class="inc-icon">${i}</span><div><div class="inc-t">${t}</div><div class="inc-s">${d}</div></div></div>`).join('')}
