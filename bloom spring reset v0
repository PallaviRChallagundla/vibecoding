const showGuide = () => {
  S.tab='guide'; save();
  if (S.unlocked) {
    render(`${pbar('Your guide')}${nav()}
<div style="text-align:center;padding:2rem 1.375rem 1rem">
  <div style="font-size:36px;margin-bottom:.75rem">🌸</div>
  <div class="t-section" style="margin-bottom:.35rem">You\'re all unlocked</div>
  <div class="t-body">All 10 rooms, every task, candle and flower guides — all yours. Your progress saves automatically.</div>
</div>
<div class="px">
  <div class="pdf-preview">
    <div class="pdf-preview-header"><div class="pdf-title">Bloom · Spring Reset Guide 2025</div><div class="pdf-sub">10 rooms · candle & flower guide · printable PDF</div></div>
    <div class="pdf-pages">
      <div class="pdf-page" style="background:#ecf4ee"><span>🌿</span><div class="pdf-page-lbl">Kitchen</div></div>
      <div class="pdf-page" style="background:var(--petal)"><span>🌸</span><div class="pdf-page-lbl">Bedroom</div></div>
      <div class="pdf-page" style="background:#fbf3e3"><span>🕯️</span><div class="pdf-page-lbl">Scents</div></div>
