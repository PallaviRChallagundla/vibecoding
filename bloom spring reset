const submitAuth = async () => {
  const email = $('authEmail')?.value?.trim();
  const pass = $('authPass')?.value;
  const name = $('authName')?.value?.trim();
  const btn = $('authSubmit');
  if (!email || !pass) { showAuthError('Please fill in all fields'); return; }
  if (pass.length < 6) { showAuthError('Password must be at least 6 characters'); return; }
  if (btn) { btn.innerHTML = '<div class="spinner"></div>'; btn.disabled = true; }

  // If Supabase is not configured, use demo mode
  if (false) { // Supabase configured
    S.user = { id: 'demo_' + email, email, user_metadata: { full_name: name || email } };
    S.unlocked = true;
    S.screen = 'app';
    save();
    showLoading();
    setTimeout(() => { updateStreak(); showChallenge(); }, 800);
    return;
  }

  try {
    let result;
    if (authMode === 'signup') {
      result = await db.auth.signUp({ email, password: pass, options: { data: { full_name: name } } });
    } else {
      result = await db.auth.signInWithPassword({ email, password: pass });
    }
    if (result.error) { showAuthError(result.error.message); if(btn){btn.innerHTML=authMode==='signup'?'Create my account →':'Sign in →';btn.disabled=false;} return; }
