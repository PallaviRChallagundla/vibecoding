  const zonePills = zones.map(z => `<div class="zone-pill${S.activeZone===z.n?' active':''}" onclick="S.activeZone=${z.n};save();showRooms()"><span class="zp-name">${z.label}</span></div>`).join('');
  const cards = ROOMS.map(r => {
    const done=rDone(r),tot=r.tasks.length,pct=rPct(r),allDone=done===tot;
    return `<div class="rc" onclick="showRoom('${r.id}')">
