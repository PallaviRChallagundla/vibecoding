<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#2d5a3f">
<meta name="description" content="Bloom — Your spring home reset ritual. Room by room. Petal by petal.">
<meta property="og:title" content="Bloom · Spring Home Reset 2026">
<meta property="og:description" content="Transform your home for spring in 7 days. A guided ritual for busy women.">
<meta property="og:image" content="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600&q=80">
<title>Bloom · Spring Home Reset</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">

<!-- Supabase SDK -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
:root{
  --sage:#2d5a3f;--sage2:#3d7554;--sage3:#6aab80;--sage4:#a8d4b4;--sagep:#edf6f0;
  --cream:#faf8f3;--petal:#f0e4da;--blush:#e8d0c4;
  --gold:#b8862a;--goldp:#fbf4e0;--goldb:#e0ca80;
  --rose:#b85a50;--lavp:#f3f0f8;--lavbdr:#c0b0e0;
  --ink:#181816;--mid:#525248;--soft:#908d84;--border:#e0d8ce;--white:#fff;
  --r:13px;--rl:20px;--rxl:28px;
  --sh:0 2px 16px rgba(0,0,0,.06);--sh2:0 8px 40px rgba(0,0,0,.1);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{background:var(--cream);font-family:'Outfit',sans-serif;color:var(--ink);font-size:15px;min-height:100vh}
#app{max-width:430px;margin:0 auto;background:var(--white);min-height:100vh;position:relative;overflow:hidden;box-shadow:var(--sh2)}
#screen{min-height:100vh}
.page{animation:pi .32s cubic-bezier(.4,0,.2,1) both}
@keyframes pi{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* ── SPRING ANIMATIONS ── */
.petal-shower{position:fixed;inset:0;pointer-events:none;z-index:9999;overflow:hidden}
.petal{position:absolute;top:-40px;font-size:18px;animation:petalFall linear forwards;opacity:0}
@keyframes petalFall{0%{transform:translateY(0) rotate(0deg) translateX(0);opacity:0}10%{opacity:1}90%{opacity:.8}100%{transform:translateY(110vh) rotate(720deg) translateX(60px);opacity:0}}
.breeze-circle{border-radius:50%;border:2px solid rgba(168,212,180,.6);animation:breezeOut .8s ease-out forwards;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:9998}
@keyframes breezeOut{0%{width:60px;height:60px;opacity:1;margin:-30px 0 0 -30px}100%{width:350px;height:350px;opacity:0;margin:-175px 0 0 -175px}}

/* ── TYPE ── */
.serif{font-family:'Cormorant',serif}
.t-body{font-size:13px;color:var(--mid);line-height:1.8;font-weight:300}
.t-label{font-size:10px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--soft)}

/* ── BUTTONS ── */
.btn{display:block;width:100%;padding:15px;border-radius:var(--r);font-family:'Outfit',sans-serif;font-size:14px;font-weight:500;cursor:pointer;text-align:center;border:none;transition:all .2s}
.btn-p{background:var(--sage);color:#fff}.btn-p:hover{background:var(--sage2)}.btn-p:active{transform:scale(.98)}
.btn-g{background:var(--gold);color:#fff}
.btn-o{background:transparent;border:1.5px solid var(--sage);color:var(--sage);margin-top:10px}.btn-o:hover{background:var(--sagep)}
.btn-gh{background:none;border:none;color:var(--soft);font-size:13px;cursor:pointer;font-family:'Outfit',sans-serif;padding:6px 0;font-weight:300}
.btn-sm{padding:10px 20px;width:auto;display:inline-block;font-size:13px}

/* ── LAYOUT ── */
.px{padding:0 1.375rem}.pt{padding-top:1.5rem}.pb{padding-bottom:2.5rem}
.gap{height:.875rem}.gap2{height:2rem}

/* ── LANDING PAGE ── */
.landing-hero{position:relative;min-height:100vh;overflow:hidden;display:flex;flex-direction:column}
.lh-bg{position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=800&q=80');background-size:cover;background-position:center}
.lh-grad{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,40,28,.2) 0%,rgba(20,40,28,.6) 50%,rgba(20,40,28,.95) 100%)}
.lh-content{position:relative;flex:1;display:flex;flex-direction:column;justify-content:flex-end;padding:2rem 1.5rem 2.5rem}
.lh-logo{font-family:'Cormorant',serif;font-size:28px;font-style:italic;color:rgba(255,255,255,.9);letter-spacing:3px;margin-bottom:1.5rem}
.lh-title{font-family:'Cormorant',serif;font-size:46px;font-weight:300;color:#fff;line-height:1.05;margin-bottom:.75rem}
.lh-title em{font-style:italic;color:var(--sage4)}
.lh-sub{font-size:13px;color:rgba(255,255,255,.6);line-height:1.85;max-width:280px;margin-bottom:2rem;font-weight:300}
.lh-cta{display:flex;flex-direction:column;gap:10px}
.lh-trust{display:flex;gap:16px;margin-top:1.125rem;justify-content:center;flex-wrap:wrap}
.lh-trust-item{font-size:11px;color:rgba(255,255,255,.45);display:flex;align-items:center;gap:4px}

/* ── AUTH CARD ── */
.auth-card{background:var(--white);border-radius:var(--rxl) var(--rxl) 0 0;padding:2rem 1.5rem 2.5rem;position:relative;box-shadow:0 -8px 40px rgba(0,0,0,.15)}
.auth-title{font-family:'Cormorant',serif;font-size:26px;font-weight:400;margin-bottom:.35rem}
.auth-sub{font-size:13px;color:var(--mid);margin-bottom:1.5rem;font-weight:300;line-height:1.65}
.auth-tabs{display:flex;background:var(--cream);border-radius:var(--r);padding:3px;margin-bottom:1.375rem;gap:3px}
.auth-tab{flex:1;padding:9px;text-align:center;border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;transition:all .18s;border:none;font-family:'Outfit',sans-serif;background:transparent;color:var(--soft)}
.auth-tab.on{background:var(--white);color:var(--sage);box-shadow:var(--sh)}
.auth-input-wrap{margin-bottom:.875rem}
.auth-label{font-size:11px;font-weight:500;color:var(--mid);margin-bottom:.35rem;display:block}
.auth-input{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:var(--r);font-family:'Outfit',sans-serif;font-size:14px;background:var(--white);color:var(--ink);outline:none;transition:border-color .18s}
.auth-input:focus{border-color:var(--sage)}
.auth-input.error{border-color:var(--rose)}
.auth-error{font-size:12px;color:var(--rose);margin-top:.5rem}
.auth-divider{display:flex;align-items:center;gap:12px;margin:1.125rem 0}
.auth-divider-line{flex:1;height:1px;background:var(--border)}
.auth-divider-text{font-size:12px;color:var(--soft)}
.social-btn{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:13px;border:1.5px solid var(--border);border-radius:var(--r);background:var(--white);font-family:'Outfit',sans-serif;font-size:14px;font-weight:500;cursor:pointer;color:var(--ink);transition:all .18s;margin-bottom:8px}
.social-btn:hover{border-color:var(--sage);background:var(--sagep)}
.social-btn svg{width:18px;height:18px;flex-shrink:0}
.auth-terms{font-size:11px;color:var(--soft);text-align:center;margin-top:1rem;line-height:1.65}

/* ── NAV ── */
.nav{display:flex;background:rgba(255,255,255,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none;position:sticky;top:0;z-index:50}
.nav::-webkit-scrollbar{display:none}
.nv{flex:1;min-width:48px;padding:13px 2px 12px;font-size:11px;font-weight:500;cursor:pointer;border-bottom:2.5px solid transparent;color:var(--soft);background:none;border-top:none;border-left:none;border-right:none;font-family:'Outfit',sans-serif;text-align:center;white-space:nowrap;transition:all .2s}
.nv.on{color:var(--sage);border-bottom-color:var(--sage)}

/* ── APP HEADER ── */
.app-hdr{background:var(--sage);padding:1.125rem 1.375rem;display:flex;align-items:center;justify-content:space-between}
.app-hdr-logo{font-family:'Cormorant',serif;font-size:20px;font-style:italic;color:#fff;letter-spacing:2px}
.app-hdr-user{display:flex;align-items:center;gap:8px;cursor:pointer}
.app-hdr-avatar{width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,.2);border:1.5px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;color:#fff}
.app-hdr-name{font-size:12px;color:rgba(255,255,255,.7)}

/* ── PROGRESS BAR ── */
.pbar{background:var(--sage);padding:1rem 1.5rem 1.375rem;position:relative;overflow:hidden}
.pbar::after{content:'🌸';position:absolute;right:-10px;bottom:-15px;font-size:80px;opacity:.07;pointer-events:none}
.pbar-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.5rem}
.pbar-title{font-family:'Cormorant',serif;font-size:18px;color:#fff;font-weight:300;font-style:italic}
.pbar-pct{font-size:26px;font-weight:500;color:#fff;line-height:1}
.pbar-sub{font-size:11px;color:rgba(255,255,255,.38);margin-top:2px}
.pbar-track{background:rgba(255,255,255,.18);border-radius:99px;height:4px;overflow:hidden}
.pbar-fill{height:100%;background:var(--gold);border-radius:99px;transition:width .8s cubic-bezier(.4,0,.2,1)}

/* ── 7 DAY CHALLENGE ── */
.challenge-hero{background:linear-gradient(135deg,#1a3a28 0%,var(--sage) 100%);padding:1.75rem 1.375rem 2rem;position:relative;overflow:hidden}
.challenge-hero::before{content:'7';font-family:'Cormorant',serif;font-size:140px;font-weight:500;color:rgba(255,255,255,.06);position:absolute;right:-10px;top:-20px;line-height:1}
.ch-tag{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:.6rem}
.ch-title{font-family:'Cormorant',serif;font-size:28px;font-weight:300;color:#fff;line-height:1.15;margin-bottom:.4rem}
.ch-title em{font-style:italic;color:var(--sage4)}
.ch-sub{font-size:12px;color:rgba(255,255,255,.55);line-height:1.75;margin-bottom:1.125rem;font-weight:300;max-width:280px}
.ch-stats{display:flex;gap:16px}
.ch-stat{text-align:center;background:rgba(255,255,255,.1);border-radius:var(--r);padding:.625rem 1rem}
.ch-stat-n{font-family:'Cormorant',serif;font-size:24px;font-weight:400;color:#fff;display:block}
.ch-stat-l{font-size:10px;color:rgba(255,255,255,.5);margin-top:1px}
.day-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;padding:1rem 1.375rem .875rem}
.day-dot{border-radius:var(--r);aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;border:1.5px solid var(--border);background:var(--cream);position:relative}
.day-dot.today{border-color:var(--sage);background:var(--sagep)}
.day-dot.done{background:var(--sage);border-color:var(--sage)}
.day-dot.done .dd-n{color:#fff}
.day-dot.done .dd-l{color:rgba(255,255,255,.7)}
.day-dot.locked{opacity:.4;cursor:default}
.dd-n{font-size:11px;font-weight:500;color:var(--ink);display:block}
.dd-l{font-size:9px;color:var(--soft);display:block;margin-top:1px}
.dd-check{position:absolute;top:3px;right:3px;font-size:9px}
.day-card{margin:0 1.375rem .875rem;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;box-shadow:var(--sh)}
.dc-header{padding:1.125rem 1.25rem;background:var(--sagep);border-bottom:1px solid var(--border)}
.dc-day{font-size:10px;font-weight:500;color:var(--soft);letter-spacing:1px;text-transform:uppercase;margin-bottom:2px}
.dc-title{font-family:'Cormorant',serif;font-size:20px;font-weight:400;color:var(--sage)}
.dc-sub{font-size:12px;color:var(--sage2);margin-top:3px;font-weight:300}
.dc-tasks{padding:.875rem 1.25rem 1.25rem}
.dc-tr{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer}
.dc-tr:last-child{border-bottom:none}
.dc-chk{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .22s;margin-top:1px;background:var(--white)}
.dc-chk.on{background:var(--sage);border-color:var(--sage);animation:cp .3s cubic-bezier(.4,0,.2,1)}
@keyframes cp{0%{transform:scale(1)}50%{transform:scale(1.3)}100%{transform:scale(1)}}
.dc-chk svg{display:none;width:9px;height:7px;stroke:#fff;stroke-width:2.5;fill:none}
.dc-chk.on svg{display:block}
.dc-t{font-size:13px;color:var(--ink);line-height:1.5}
.dc-tr.done .dc-t{text-decoration:line-through;color:var(--soft)}
.dc-m{font-size:10px;color:var(--soft);margin-top:2px}
.challenge-complete{background:var(--sage);border-radius:var(--rl);margin:0 1.375rem .875rem;padding:1.5rem;text-align:center}
.cc-emoji{font-size:40px;display:block;margin-bottom:.625rem}
.cc-title{font-family:'Cormorant',serif;font-size:22px;font-weight:300;color:#fff;margin-bottom:.35rem}
.cc-sub{font-size:12px;color:rgba(255,255,255,.6);line-height:1.7}
.challenge-cta{margin:0 1.375rem .875rem}

/* ── ROOMS ── */
.rooms-feed{display:flex;flex-direction:column;gap:0}
.rc{background:var(--white);border-bottom:1px solid var(--border);cursor:pointer;transition:all .2s;overflow:hidden}
.rc:active{background:var(--cream)}
.rc-img{height:110px;position:relative;overflow:hidden;background-size:cover;background-position:center}
.rc-img-ov{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:space-between;padding:10px 14px;background:linear-gradient(to top,rgba(0,0,0,.52) 0%,transparent 70%)}
.rc-tag{font-size:10px;font-weight:500;padding:4px 10px;border-radius:99px;backdrop-filter:blur(8px);background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.25);color:#fff}
.rc-time{font-size:10px;color:rgba(255,255,255,.9);font-weight:500;background:rgba(0,0,0,.3);padding:3px 8px;border-radius:99px}
.rc-body{padding:12px 16px 14px}
.rc-ey{font-size:10px;font-weight:500;color:var(--soft);letter-spacing:.7px;text-transform:uppercase;margin-bottom:2px}
.rc-title{font-family:'Cormorant',serif;font-size:19px;font-weight:400;color:var(--ink);margin-bottom:4px}
.rc-desc{font-size:12px;color:var(--mid);line-height:1.65;margin-bottom:8px;font-weight:300}
.rc-chips{display:flex;gap:5px;margin-bottom:9px;flex-wrap:wrap}
.chip{font-size:10px;padding:3px 9px;border-radius:99px;border:1px solid var(--border);color:var(--mid);display:flex;align-items:center;gap:3px;white-space:nowrap;background:var(--cream)}
.rc-foot{display:flex;align-items:center;gap:10px}
.rc-bar{flex:1;height:3px;background:var(--border);border-radius:99px;overflow:hidden}
.rc-bfill{height:100%;border-radius:99px;transition:width .6s ease}
.rc-cnt{font-size:11px;color:var(--soft);white-space:nowrap}
.rc-btn{font-size:12px;font-weight:500;color:var(--sage);padding:5px 12px;border:1px solid var(--sage);border-radius:99px;background:transparent;cursor:pointer;font-family:'Outfit',sans-serif;white-space:nowrap;transition:all .18s}
.rc-btn.done{background:var(--sage);color:#fff}

/* ── ROOM DETAIL ── */
.rd-hero{height:180px;position:relative;overflow:hidden;background-size:cover;background-position:center}
.rd-ov{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.05),rgba(0,0,0,.65))}
.rd-hc{position:absolute;bottom:0;left:0;right:0;padding:1.125rem 1.375rem}
.rd-ey{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.58);margin-bottom:.25rem}
.rd-h{font-family:'Cormorant',serif;font-size:26px;font-weight:300;color:#fff;line-height:1.15}
.rd-h em{font-style:italic}
.rd-topbar{display:flex;align-items:center;justify-content:space-between;padding:.875rem 1.375rem;border-bottom:1px solid var(--border)}
.rd-body{padding:1.125rem 1.375rem 2.5rem}
.rd-quote{font-family:'Cormorant',serif;font-size:15px;font-style:italic;line-height:1.8;color:var(--mid);margin-bottom:1.125rem;padding-bottom:1.125rem;border-bottom:1px solid var(--border)}
.v3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:1.125rem}
.v3c{background:var(--cream);border:1px solid var(--border);border-radius:var(--r);padding:9px 7px;text-align:center}
.v3i{font-size:17px;display:block;margin-bottom:3px}
.v3l{font-size:9px;font-weight:500;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:2px}
.v3v{font-family:'Cormorant',serif;font-size:12px;font-style:italic;color:var(--ink);display:block;line-height:1.4}
.tasks-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:.875rem}
.tasks-pill{font-size:11px;padding:3px 10px;border-radius:99px;background:var(--sagep);color:var(--sage);font-weight:500}
.tr{display:flex;align-items:flex-start;gap:11px;padding:11px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:opacity .15s;user-select:none}
.tr:last-child{border-bottom:none}
.tr.lk{cursor:default;opacity:.28}
.tr:not(.lk):active{opacity:.65}
.chk{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .22s;margin-top:1px;background:var(--white)}
.chk.on{background:var(--sage);border-color:var(--sage);animation:cp .3s cubic-bezier(.4,0,.2,1)}
.chk svg{display:none;width:10px;height:8px;stroke:#fff;stroke-width:2.5;fill:none}
.chk.on svg{display:block}
.lkic{width:12px;height:12px;flex-shrink:0;opacity:.3;margin-top:3px}
.tn{font-size:13px;line-height:1.5;color:var(--ink)}
.tr.done .tn{text-decoration:line-through;color:var(--soft)}
.tmeta{font-size:11px;color:var(--soft);margin-top:2px}
.tb{font-size:10px;padding:1px 6px;border-radius:99px;font-weight:500;margin-left:4px;vertical-align:middle}
.tbd{background:#e5eee8;color:#1a4228}.tbq{background:#fdf0db;color:#7a4a06}
.tbr{background:#e5edf8;color:#1a3a6b}.tbc{background:#fae5e8;color:#6b1a22}

/* ── TIMER ── */
.timer-box{background:var(--sage);border-radius:var(--rl);margin:0 1.375rem 12px;padding:1.75rem 1.25rem 1.5rem;text-align:center;box-shadow:var(--sh2)}
.t-lbl{font-size:10px;letter-spacing:2px;color:rgba(255,255,255,.38);text-transform:uppercase;margin-bottom:.5rem}
.t-dig{font-family:'Cormorant',serif;font-size:70px;font-weight:300;color:#fff;letter-spacing:5px;line-height:1;font-variant-numeric:tabular-nums}
.t-track{background:rgba(255,255,255,.12);border-radius:99px;height:4px;margin:1rem 0;overflow:hidden}
.t-fill{height:100%;background:var(--gold);border-radius:99px;transition:width 1s linear}
.t-btns{display:flex;gap:8px;justify-content:center;margin-top:.875rem}
.tbtn2{padding:11px 26px;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Outfit',sans-serif;border:none;transition:all .18s}
.tb2-s{background:var(--gold);color:#fff}.tb2-r{background:rgba(255,255,255,.1);color:rgba(255,255,255,.7)}
.timer-mode-bar{display:flex;gap:6px;padding:0 1.375rem;margin-bottom:.875rem;flex-wrap:wrap}
.tm-btn{padding:8px 12px;border-radius:99px;font-size:11px;font-weight:500;cursor:pointer;border:1.5px solid var(--border);background:var(--white);color:var(--mid);font-family:'Outfit',sans-serif;transition:all .18s}
.tm-btn.on{background:var(--sage);border-color:var(--sage);color:#fff}
.custom-timer-box{background:var(--cream);border:1px solid var(--border);border-radius:var(--rl);padding:1.125rem;margin:0 1.375rem 1rem}
.ct-row{display:flex;gap:8px;align-items:center;margin-top:.5rem}
.ct-in{width:72px;padding:10px 12px;border:1.5px solid var(--border);border-radius:var(--r);font-family:'Outfit',sans-serif;font-size:18px;font-weight:500;text-align:center;background:var(--white);color:var(--ink);outline:none}
.ct-in:focus{border-color:var(--sage)}
.ct-set{padding:10px 16px;background:var(--sage);color:#fff;border:none;border-radius:var(--r);font-family:'Outfit',sans-serif;font-size:13px;font-weight:500;cursor:pointer}

/* ── STREAK ── */
.streak-band{background:var(--goldp);border-bottom:1px solid var(--goldb);padding:.875rem 1.375rem;display:flex;align-items:center;gap:12px}
.flame{font-size:24px;animation:fl 2s ease-in-out infinite}
@keyframes fl{0%,100%{transform:scale(1) rotate(-2deg)}50%{transform:scale(1.1) rotate(2deg)}}
.streak-badge{margin-left:auto;background:var(--gold);color:#fff;font-size:11px;font-weight:500;padding:4px 10px;border-radius:99px}

/* ── ZONE BAND ── */
.zone-band{background:var(--white);border-bottom:1px solid var(--border);padding:.75rem 1.375rem}
.zone-row{display:flex;gap:7px;overflow-x:auto;scrollbar-width:none}
.zone-row::-webkit-scrollbar{display:none}
.zone-pill{flex-shrink:0;padding:6px 12px;border-radius:99px;border:1.5px solid var(--border);background:var(--cream);cursor:pointer;transition:all .2s}
.zone-pill.active{background:var(--sage);border-color:var(--sage);color:#fff}
.zp-name{font-size:11px;font-weight:500;display:block;white-space:nowrap}
.zp-sub{font-size:9px;opacity:.65;display:block;margin-top:1px}

/* ── LOCK NUDGE ── */
.lock-n{background:var(--goldp);border:1.5px solid var(--goldb);padding:.875rem 1.375rem;display:flex;align-items:center;justify-content:space-between;margin:.5rem 1.375rem;border-radius:var(--r);cursor:pointer;transition:opacity .18s}
.lock-n:hover{opacity:.88}
.ln-t{font-weight:500;font-size:13px;color:#5a3808}
.ln-s{font-size:11px;color:#8a6018;margin-top:2px}
.ln-cta{font-size:13px;font-weight:500;color:var(--gold);white-space:nowrap}

/* ── AFFIRM ── */
.affirm{background:var(--petal);border:1px solid var(--blush);border-radius:var(--rl);padding:1rem 1.25rem;margin:1rem 1.375rem}
.affirm-t{font-family:'Cormorant',serif;font-size:15px;font-style:italic;color:#5a2218;line-height:1.8}

/* ── PROFILE ── */
.profile-card{margin:1.375rem;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;box-shadow:var(--sh)}
.pc-header{background:var(--sage);padding:1.5rem;display:flex;align-items:center;gap:14px}
.pc-avatar{width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.2);border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:500;color:#fff}
.pc-name{font-family:'Cormorant',serif;font-size:20px;color:#fff;font-weight:400}
.pc-email{font-size:12px;color:rgba(255,255,255,.55);margin-top:2px}
.pc-body{padding:1.125rem}
.pc-row{display:flex;align-items:center;justify-content:space-between;padding:.875rem 0;border-bottom:1px solid var(--border)}
.pc-row:last-child{border-bottom:none}
.pc-lbl{font-size:13px;color:var(--mid)}
.pc-val{font-size:13px;font-weight:500;color:var(--ink)}
.pc-signout{width:100%;margin-top:1rem;padding:13px;background:var(--rosep);color:var(--rose);border:1.5px solid #f0b0a8;border-radius:var(--r);font-family:'Outfit',sans-serif;font-size:14px;font-weight:500;cursor:pointer;transition:all .18s}
.pc-signout:hover{background:#fde0dc}

/* ── TOAST ── */
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:var(--sage);color:#fff;padding:12px 20px;border-radius:var(--r);font-size:13px;font-weight:500;z-index:9990;animation:tIn .4s cubic-bezier(.4,0,.2,1) both,tOut .4s .2s ease 2.5s both;white-space:nowrap;box-shadow:var(--sh2)}
@keyframes tIn{from{opacity:0;transform:translateX(-50%) translateY(20px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
@keyframes tOut{from{opacity:1}to{opacity:0;transform:translateX(-50%) translateY(10px)}}

/* ── LOADING ── */
.loading-scr{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background:var(--sage);gap:1rem}
.loading-logo{font-family:'Cormorant',serif;font-size:36px;font-style:italic;color:#fff;letter-spacing:3px}
.loading-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.4);animation:pulse 1.4s ease-in-out infinite}
.loading-dot:nth-child(2){animation-delay:.2s}
.loading-dot:nth-child(3){animation-delay:.4s}
.loading-dots{display:flex;gap:6px}
@keyframes pulse{0%,80%,100%{transform:scale(0);opacity:.4}40%{transform:scale(1);opacity:1}}

/* ── DONE ── */
.done-scr{text-align:center;padding:5rem 2rem}

/* ── SPINNER ── */
.spinner{width:32px;height:32px;border:2.5px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto}
@keyframes spin{to{transform:rotate(360deg)}}
