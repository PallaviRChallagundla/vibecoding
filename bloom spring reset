          <span class="chip">🕯️ ${r.candle.split(' or ')[0].split(',')[0]}</span>
          <span class="chip">💐 ${r.flower.split('·')[0].trim().split('—')[0].trim()}</span>
        </div>
        <div class="rc-foot">
          <div class="rc-bar"><div class="rc-bfill" style="width:${pct}%;background:${pct===100?'var(--sage)':'var(--gold)'}"></div></div>
          <span class="rc-cnt">${done}/${tot}</span>
          <button class="rc-btn${allDone?' done':''}" onclick="event.stopPropagation();showRoom('${r.id}')">${allDone?'✓ Done':'Open →'}</button>
        </div>
      </div>
    </div>`;
  }).join('');
  render(`<div class="page">
${appHeader()}
${pbar('Bloom · 2026')}
${nav('rooms')}
${S.streak>=2?streakBand():''}
<div class="zone-band"><div class="t-label" style="margin-bottom:.4rem">Focus zones</div><div class="zone-row">${zonePills}</div></div>
<div class="affirm"><div class="affirm-t">"${affirm}"</div></div>
<div class="rooms-feed">${cards}</div>
${!S.unlocked?`<div class="lock-n" onclick="showToast('All rooms unlocked for you!')"><div><div class="ln-t">Unlock all 10 rooms free</div><div class="ln-s">Enter your email — instant access</div></div><span class="ln-cta">Get access →</span></div>`:''}
<div class="gap2"></div>
</div>`);
};

// ── ROOM DETAIL ───────────────────────────────────────────────────────────────
const showRoom = id => {
  S.activeRoom = id; save();
  const r = ROOMS.find(x => x.id===id);
  const done=rDone(r),tot=r.tasks.length;
  const rows = r.tasks.map(t => {
    const dn=!!S.tasks[t.id],lkd=!S.unlocked&&!t.free;
    return `<div class="tr${dn?' done':''}${lkd?' lk':''}" onclick="${lkd?'showToast(\'Unlock to access all tasks\')':'toggleTask(\''+t.id+'\')'}">${lkd?lksv():`<div class="chk${dn?' on':''}">${csv()}</div>`}<div class="td"><span class="tn">${t.t}</span><span class="tb ${t.b}">${bl(t.b)}</span><div class="tmeta">${fmtTime(t.m)}${lkd?' · <span style="color:var(--gold);font-weight:500">unlock</span>':''}</div></div></div>`;
  }).join('');
  render(`<div class="page">
<div class="rd-hero" style="background-image:url('${PH[r.id]||PH.cover}')">
  <div class="rd-ov"></div>
  <div class="rd-hc"><div class="rd-ey">${r.label}</div><div class="rd-h">${r.title.split(' ').slice(0,4).join(' ')}<br><em>${r.title.split(' ').slice(4).join(' ')}</em></div></div>
</div>
<div class="rd-topbar"><button class="btn-gh" onclick="showRooms()">← rooms</button><span style="font-size:12px;color:var(--soft)">${done}/${tot} done</span></div>
<div class="rd-body">
  <div class="rd-quote">${r.desc}</div>
  <div class="v3">
    <div class="v3c"><span class="v3i">🕯️</span><span class="v3l">Candle</span><span class="v3v">${r.candle.split(' or ')[0].split(',')[0]}</span></div>
    <div class="v3c"><span class="v3i">💐</span><span class="v3l">Flower</span><span class="v3v">${r.flower.split('·')[0].trim().split(' ').slice(0,4).join(' ')}</span></div>
    <div class="v3c"><span class="v3i">✨</span><span class="v3l">One swap</span><span class="v3v">${r.swap.split(' ').slice(0,4).join(' ')}…</span></div>
  </div>
  <div class="tasks-hd"><div style="font-family:'Cormorant',serif;font-size:19px;font-weight:400">Tasks</div><span class="tasks-pill">${done}/${tot}</span></div>
  ${rows}
</div>
<div style="padding:.875rem 1.375rem 2.5rem">
  <button class="btn btn-o" onclick="S.activeRoom='${r.id}';setTab('timer')">⏱ Start focus timer for this room</button>
</div>
</div>`);
};

const toggleTask = id => {
  const task = ROOMS.flatMap(r=>r.tasks).find(t=>t.id===id);
  if (!task) return;
  if (!S.unlocked && !task.free) { showToast('All rooms unlocked for you!'); return; }
  const was = !!S.tasks[id]; S.tasks[id] = !was;
  updateStreak(); save();
  if (!was) {
    const room = ROOMS.find(r=>r.tasks.some(t=>t.id===id));
    if (room && rDone(room)===room.tasks.length) { springPetals(); breezeAnim(); showToast(`🌸 ${room.label} complete!`); }
  }
  if (S.activeRoom) showRoom(S.activeRoom); else showRooms();
};

// ── TIMER ─────────────────────────────────────────────────────────────────────
const showTimer = () => { S.tab='timer'; save(); if(TI)clearInterval(TI); renderTimer(); };
const renderTimer = () => {
  const l=S.tLeft,m=Math.floor(l/60),secs=l%60;
  const disp=`${String(m).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
  const pct=Math.round((1-l/S.tBase)*100);
  const r=S.activeRoom?ROOMS.find(x=>x.id===S.activeRoom):null;
  const ft=r?r.tasks.filter(t=>S.unlocked||t.free).slice(0,3):CHALLENGE_DAYS[getChallengeDay()-1]?.tasks.slice(0,3)||[];
  render(`<div class="page">
${appHeader()}${nav('timer')}
<div style="height:.875rem"></div>
<div class="timer-mode-bar">
  <button class="tm-btn${S.tMode===15?' on':''}" onclick="setT(15)">⚡ 15 min</button>
  <button class="tm-btn${S.tMode===30?' on':''}" onclick="setT(30)">🌿 30 min</button>
  <button class="tm-btn${S.tMode===60?' on':''}" onclick="setT(60)">💪 1 hour</button>
  <button class="tm-btn${S.tMode===300?' on':''}" onclick="setT(300)" style="${S.tMode===300?'':'border-color:var(--gold);color:var(--gold)'}">🌸 Weekend (5h)</button>
</div>
<div class="timer-box">
  <div class="t-lbl">${r?r.label+' · focus time':'Bloom timer'}</div>
  <div class="t-dig">${disp}</div>
  <div class="t-track"><div class="t-fill" style="width:${pct}%"></div></div>
  <div class="t-btns">
    <button class="tbtn2 tb2-r" onclick="resetT()">Reset</button>
    <button class="tbtn2 tb2-s" onclick="togT()">${S.tOn?'Pause ⏸':'Start ▶'}</button>
  </div>
</div>
<div class="custom-timer-box">
  <div style="font-family:'Cormorant',serif;font-size:17px;font-weight:400;margin-bottom:.25rem">Custom timer</div>
  <div style="font-size:12px;color:var(--mid);font-weight:300">Set any duration you want</div>
  <div class="ct-row">
    <input class="ct-in" type="number" id="ctMin" placeholder="45" min="1" max="480" value="${S.tMode}" />
    <span style="font-size:13px;color:var(--mid)">minutes</span>
    <button class="ct-set" onclick="setCustomTimer()">Set</button>
  </div>
</div>
<div style="font-family:'Cormorant',serif;font-size:14px;font-style:italic;color:var(--mid);text-align:center;padding:.75rem 2rem .875rem;line-height:1.8">"Put on something you love. Light a candle. Set the timer. Stop when it rings."</div>
<div style="margin:0 1.375rem;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:1.125rem">
  <div style="font-family:'Cormorant',serif;font-size:17px;font-weight:400;margin-bottom:.75rem">${r?r.label+' tasks':'Today\'s challenge tasks'}</div>
  ${ft.map(t=>{
    const dn=r?!!S.tasks[t.id]:!!S.challengeTasks[t.id];
    const fn=r?`toggleTask('${t.id}')`:`toggleChallenge('${t.id}')`;
    return`<div class="tr${dn?' done':''}" onclick="${fn}"><div class="chk${dn?' on':''}">${csv()}</div><div class="td"><span class="tn">${t.t}</span><div class="tmeta">${fmtTime(t.m)}</div></div></div>`;
  }).join('')}
</div>
<div class="gap2"></div>
</div>`);
};

const setT=m=>{if(TI)clearInterval(TI);S.tOn=false;S.tMode=m;S.tLeft=m*60;S.tBase=m*60;save();renderTimer()};
const resetT=()=>{if(TI)clearInterval(TI);S.tOn=false;S.tLeft=S.tBase;save();renderTimer()};
const setCustomTimer=()=>{const el=$('ctMin');if(!el)return;const m=parseInt(el.value)||15;if(m<1||m>480)return;setT(m)};
const togT=()=>{
  if(S.tOn){clearInterval(TI);S.tOn=false;save();renderTimer();return}
  S.tOn=true;save();renderTimer();
  TI=setInterval(()=>{
    if(S.tLeft<=0){clearInterval(TI);S.tOn=false;S.tLeft=0;save();springPetals();breezeAnim();
      render(`<div class="page"><div class="done-scr"><div style="font-size:52px;margin-bottom:1.25rem">🌿</div><div style="font-family:'Cormorant',serif;font-size:26px;font-weight:400;margin-bottom:.5rem">Session complete.</div><p style="font-size:13px;color:var(--mid);max-width:240px;margin:0 auto 2rem;line-height:1.8;font-weight:300">You showed up for your home today.</p><button class="btn btn-p" style="max-width:220px;margin:0 auto" onclick="setTab('challenge')">See my progress →</button></div></div>`);return;
    }
    S.tLeft--;save();renderTimer();
  },1000);
};

// ── PROFILE ───────────────────────────────────────────────────────────────────
const showProfile = () => {
  S.tab = 'profile'; save();
  const name = S.user?.user_metadata?.full_name || S.user?.email?.split('@')[0] || 'You';
  const initial = name[0]?.toUpperCase() || '?';
  const prog = challengeProgress();
  render(`<div class="page">
${appHeader()}${nav('profile')}
<div class="profile-card">
  <div class="pc-header">
    <div class="pc-avatar">${initial}</div>
    <div><div class="pc-name">${name}</div><div class="pc-email">${S.user?.email||'demo@bloom.app'}</div></div>
  </div>
  <div class="pc-body">
    <div class="pc-row"><span class="pc-lbl">Challenge progress</span><span class="pc-val">${prog.done}/${prog.total} tasks · ${prog.pct}%</span></div>
    <div class="pc-row"><span class="pc-lbl">Rooms reset</span><span class="pc-val">${ROOMS.filter(r=>rPct(r)===100).length} of ${ROOMS.length}</span></div>
    <div class="pc-row"><span class="pc-lbl">Current streak</span><span class="pc-val">${S.streak||0} day${S.streak!==1?'s':''} 🔥</span></div>
    <div class="pc-row"><span class="pc-lbl">Progress saved</span><span class="pc-val">${db&&S.user?.id&&!S.user.id.startsWith('demo_')?'☁️ Cloud sync':'💾 Local'}</span></div>
    <button class="pc-signout" onclick="signOut()">Sign out</button>
  </div>
</div>
<div style="padding:.875rem 1.375rem 2.5rem">
  <div style="background:var(--sagep);border:1px solid var(--sage3);border-radius:var(--rl);padding:1.125rem;margin-bottom:.875rem">
    <div style="font-family:'Cormorant',serif;font-size:17px;font-weight:400;color:var(--sage);margin-bottom:.35rem">Printable guide</div>
    <div style="font-size:12px;color:var(--sage2);line-height:1.7;font-weight:300">A beautiful 28-page printable PDF is coming soon — candle pairings, flower guide, room mood boards. Free for all members.</div>
    <div style="display:inline-flex;align-items:center;gap:4px;background:var(--goldp);border:1px solid var(--goldb);color:#7a4a06;font-size:10px;font-weight:500;padding:3px 9px;border-radius:99px;margin-top:.625rem">⏳ Coming soon</div>
  </div>
</div>
</div>`);
};

const signOut = async () => {
  if (db && !S.user?.id?.startsWith('demo_')) await db.auth.signOut();
  S.user = null; S.screen = 'landing';
  save(); showLanding();
};

// ══════════════════════════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════════════════════════
const init = async () => {
  showLoading();

  // Check for existing Supabase session
  if (db && SUPABASE_URL !== 'YOUR_SUPABASE_URL') {
    try {
      const { data: { session } } = await db.auth.getSession();
      if (session?.user) {
        S.user = session.user;
        S.unlocked = true;
        S.screen = 'app';
        await loadFromCloud();
        updateStreak();
        setTab(S.tab || 'challenge');
        return;
      }
    } catch(e) {}
  }

  // Check local session (demo mode)
  if (S.user && S.screen === 'app') {
    setTab(S.tab || 'challenge');
    return;
  }

  showLanding();
};

init();
</script>

<script>
// ── SERVICE WORKER (offline support) ─────────────────────────────────────────
if ('serviceWorker' in navigator) {
  const swCode = `
    const CACHE = 'bloom-v1';
    const ASSETS = ['/'];
    self.addEventListener('install', e => {
      e.waitUntil(caches.open(CACHE).then(c => c.addAll(ASSETS)));
      self.skipWaiting();
    });
    self.addEventListener('activate', e => {
      e.waitUntil(caches.keys().then(keys =>
        Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k)))
      ));
      self.clients.claim();
    });
    self.addEventListener('fetch', e => {
      e.respondWith(
        fetch(e.request).catch(() => caches.match(e.request))
      );
    });
  `;
  const blob = new Blob([swCode], {type: 'application/javascript'});
  const swUrl = URL.createObjectURL(blob);
  navigator.serviceWorker.register(swUrl).catch(() => {});
}

// ── INSTALL PROMPT ────────────────────────────────────────────────────────────
let deferredPrompt = null;

window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  // Show install banner after 3 seconds
  setTimeout(showInstallBanner, 3000);
});

function showInstallBanner() {
  if (!deferredPrompt) return;
  if (localStorage.getItem('bloom_install_dismissed')) return;

  const banner = document.createElement('div');
  banner.id = 'install-banner';
  banner.style.cssText = `
    position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 100%; max-width: 430px; background: #2d5a3f; color: #fff;
    padding: 16px 20px; display: flex; align-items: center; gap: 12px;
    z-index: 99999; box-shadow: 0 -4px 20px rgba(0,0,0,.2);
    font-family: 'Outfit', sans-serif; animation: slideUp .3s ease;
  `;
  banner.innerHTML = `
    <style>@keyframes slideUp{from{transform:translateX(-50%) translateY(100%)}to{transform:translateX(-50%) translateY(0)}}</style>
    <span style="font-size:28px;flex-shrink:0">🌸</span>
    <div style="flex:1">
      <div style="font-size:13px;font-weight:500">Add Bloom to your home screen</div>
      <div style="font-size:11px;color:rgba(255,255,255,.6);margin-top:2px">Works like a real app — no App Store needed</div>
    </div>
    <button onclick="installApp()" style="padding:8px 16px;background:#b8862a;color:#fff;border:none;border-radius:8px;font-family:'Outfit',sans-serif;font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap">Install</button>
    <button onclick="dismissInstall()" style="background:none;border:none;color:rgba(255,255,255,.5);font-size:20px;cursor:pointer;padding:0 4px;line-height:1">×</button>
  `;
  document.body.appendChild(banner);
}

function installApp() {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  deferredPrompt.userChoice.then(result => {
    if (result.outcome === 'accepted') {
      const banner = document.getElementById('install-banner');
      if (banner) banner.remove();
    }
    deferredPrompt = null;
  });
}

function dismissInstall() {
  const banner = document.getElementById('install-banner');
  if (banner) banner.remove();
  localStorage.setItem('bloom_install_dismissed', '1');
}

// ── iOS INSTALL INSTRUCTIONS ──────────────────────────────────────────────────
// iOS doesn't support beforeinstallprompt — show manual instructions
const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
const isInStandaloneMode = window.navigator.standalone === true;

if (isIOS && !isInStandaloneMode && !localStorage.getItem('bloom_ios_dismissed')) {
  setTimeout(() => {
    const banner = document.createElement('div');
    banner.style.cssText = `
      position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 430px; background: #2d5a3f; color: #fff;
      padding: 16px 20px; z-index: 99999;
      box-shadow: 0 -4px 20px rgba(0,0,0,.2);
      font-family: 'Outfit', sans-serif; animation: slideUp .3s ease;
      border-radius: 16px 16px 0 0;
    `;
    banner.innerHTML = `
      <style>@keyframes slideUp{from{transform:translateX(-50%) translateY(100%)}to{transform:translateX(-50%) translateY(0)}}</style>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <div style="display:flex;align-items:center;gap:8px">
          <span style="font-size:22px">🌸</span>
          <div style="font-size:13px;font-weight:500">Add Bloom to your iPhone</div>
        </div>
        <button onclick="this.closest('div[style]').remove();localStorage.setItem('bloom_ios_dismissed','1')" style="background:none;border:none;color:rgba(255,255,255,.5);font-size:20px;cursor:pointer;padding:0">×</button>
      </div>
      <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:10px 12px;font-size:12px;color:rgba(255,255,255,.85);line-height:1.8">
        1. Tap the <strong>Share button</strong> at the bottom of Safari (the box with an arrow)<br>
        2. Scroll down and tap <strong>"Add to Home Screen"</strong><br>
        3. Tap <strong>"Add"</strong> — Bloom appears on your home screen like a real app
      </div>
    `;
    document.body.appendChild(banner);
  }, 4000);
}
</script>
