  <div style="font-family:'Cormorant',serif;font-size:15px;font-style:italic;color:var(--mid);line-height:1.8;margin-bottom:1.25rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border)">"${d.sub}"</div>
  ${d.tasks.map(t=>{const dn=!!S.challengeTasks[t.id];return`<div class="dc-tr${dn?' done':''}" onclick="toggleChallenge('${t.id}')"><div class="dc-chk${dn?' on':''}">${dn?csv():''}</div><div style="flex:1"><div class="dc-t">${t.t}</div><div class="dc-m">⏱ ${t.m} min</div></div></div>`}).join('')}
</div>
</div>`);
};

const toggleChallenge = (id) => {
  S.challengeTasks[id] = !S.challengeTasks[id];
  updateStreak(); save();
  // Check if day is now complete
  const day = CHALLENGE_DAYS.find(d => d.tasks.some(t => t.id===id));
  if (day && day.tasks.every(t => S.challengeTasks[t.id])) {
    springPetals(); breezeAnim();
    showToast(`🌸 Day ${day.day} complete! You're blooming.`);
  }
  if ($('screen')?.innerHTML.includes('showChallengeDay')) showChallengeDay(getChallengeDay());
  else showChallenge();
};

// ── ROOMS ─────────────────────────────────────────────────────────────────────
const showRooms = () => {
  S.tab = 'rooms'; S.activeRoom = null; save(); updateStreak();
  const affirm = AFFIRMS[dnCount() % AFFIRMS.length];
  const zones = [
    {n:1,label:'Zone 1 · Surface',rooms:['kitchen','living','entryway']},
    {n:2,label:'Zone 2 · Deeper',rooms:['bedroom','bathroom','office','kids','dining']},
    {n:3,label:'Zone 3 · Systems',rooms:['guest','systems']},
