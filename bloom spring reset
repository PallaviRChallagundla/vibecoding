const allIds = () => ROOMS.flatMap(r => r.tasks.map(t => t.id));
const dnCount = () => allIds().filter(id => S.tasks[id]).length;
const totPct = () => Math.round(dnCount() / allIds().length * 100);
const rDone = r => r.tasks.filter(t => S.tasks[t.id]).length;
const rPct = r => Math.round(rDone(r) / r.tasks.length * 100);
const bl = b => ({tbd:'deep clean',tbq:'quick win',tbr:'refresh',tbc:'declutter'}[b]||'');
const fmtTime = m => { if(m<60) return m+'min'; const h=Math.floor(m/60),mm=m%60; return mm?`${h}h ${mm}m`:`${h}h`; };

const getChallengeDay = () => {
  if (!S.challengeStartDate) return 1;
  const start = new Date(S.challengeStartDate);
  const now = new Date();
  const diff = Math.floor((now - start) / 86400000);
  return Math.min(diff + 1, 7);
};

const challengeDayDone = (day) => {
  const d = CHALLENGE_DAYS[day - 1];
  if (!d) return false;
  return d.tasks.every(t => S.challengeTasks[t.id]);
};

const challengeProgress = () => {
  const allT = CHALLENGE_DAYS.flatMap(d => d.tasks);
  const done = allT.filter(t => S.challengeTasks[t.id]).length;
  return { done, total: allT.length, pct: Math.round(done/allT.length*100) };
};

// ── SUPABASE SYNC ─────────────────────────────────────────────────────────────
const syncToCloud = async () => {
  if (!db || !S.user) return;
  clearTimeout(syncTimeout);
  syncTimeout = setTimeout(async () => {
    try {
      await db.from('bloom_progress').upsert({
        user_id: S.user.id,
        tasks: S.tasks,
        challenge_tasks: S.challengeTasks,
        streak: S.streak,
        last_active: S.lastActive,
        unlocked: S.unlocked,
        ob: S.ob,
        challenge_started: S.challengeStarted,
        challenge_start_date: S.challengeStartDate,
        updated_at: new Date().toISOString(),
      }, { onConflict: 'user_id' });
    } catch(e) { console.warn('Sync failed, saved locally'); }
  }, 1500);
};

const loadFromCloud = async () => {
  if (!db || !S.user) return;
  try {
    const { data } = await db.from('bloom_progress').select('*').eq('user_id', S.user.id).single();
    if (data) {
      S.tasks = data.tasks || {};
      S.challengeTasks = data.challenge_tasks || {};
      S.streak = data.streak || 0;
      S.lastActive = data.last_active;
      S.unlocked = data.unlocked || false;
      S.ob = data.ob || {};
      S.challengeStarted = data.challenge_started || false;
      S.challengeStartDate = data.challenge_start_date;
    }
  } catch(e) { console.warn('Could not load from cloud, using local data'); }
};

const save = () => {
  saveLocal();
  syncToCloud();
};

